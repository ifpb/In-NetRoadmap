---
- hosts: all
  tasks:
    - name: Enable interface
      command: ifconfig enp0s9 up
      become: yes

    - name: Enable interface
      command: ifconfig enp0s10 up
      become: yes

    - name: Compile p4 code
      # Caminho do arquivo .p4 parametrizado
      command: p4c -b bmv2 {{ p4_source_path }} -o /vagrant/bmv2.json
      become: yes

    - name: stop previous Bmv2 Switch
      shell: pkill simple_switch | true
      become: yes

    - name: Start Bmv2 Switch with decision tree
      # O caminho do .json compilado correspondente ao .p4 também foi parametrizado
      shell: simple_switch --device-id 1 --thrift-port 9090 --interface 1@enp0s9 --interface 2@enp0s10 /vagrant/bmv2.json &
      async: 1000
      poll: 5
      become: yes

    - name: Insert entries in switch table by control plane
      # Caminho da table1.txt parametrizado
      shell: cat {{ table1_path }} | simple_switch_CLI
      become: yes

    - name: Insert model entries in switch table by control plane
      # Caminho da table2.txt parametrizado
      shell: cat {{ table2_path }} | simple_switch_CLI
      become: yes

    - name: Turn off GSO, TSO and GRO
      command: ethtool --offload enp0s9 gso off tso off gro off
      become: yes

    - name: Turn off GSO, TSO and GRO
      command: ethtool --offload enp0s10 gso off tso off gro off
      become: yes
